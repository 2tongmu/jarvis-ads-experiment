;
; -- sim_options  [SIM_CTRL]  Simulator options
Options ResourceUsage=yes UseNutmegFormat=no
;
; -- SP1  [SIM_CTRL]  S-parameter sweep 2-18 GHz 50 MHz step
S_Param:SP1 CalcS=yes CalcY=no CalcZ=no StatusLevel=2 CalcNoise=no \
SweepVar="freq" SweepPlan="SP1_stim" OutputPlan="SP1_Output"
SweepPlan: SP1_stim Start=2 GHz Stop=18 GHz Step=50 MHz
OutputPlan:SP1_Output \
      Type="Output" \
      UseEquationNestLevel=yes \
      EquationNestLevel=2 \
      UseSavedEquationNestLevel=yes \
      SavedEquationNestLevel=2
;
; -- Term1  [PORT]  RF input port P1, 50 Ohm
Port:Term1  P1  0  Num=1  Z=50 Ohm
;
; -- Term2  [PORT]  RF output port P2, 50 Ohm
Port:Term2  P2  0  Num=2  Z=50 Ohm
;
; -- PAD_in  [PASSIVE_NETWORK]  Input RF bond/probe pad
R:Rpad_in   P1   n1   R=0.05 Ohm
L:Lpad_in   n1   n2   L=10 pH
C:Cpad_in   n2   0    C=65 fF
;
; -- INT_in  [TLINE]  Input 0.3mm Au interconnect, pi-model
C:Ci1a  n2   0    C=24 fF
R:Ri1   n2   n3   R=0.009 Ohm
L:Li1   n3   n4   L=120 pH
C:Ci1b  n4   0    C=24 fF
;
; -- Q1a  [TRANSISTOR]  Stage 1 series pHEMT Q1a, ON state, 160um
"PP1029_CPW_PDK":Q1a  ng_Q1a n4 n8  NOF=2  UGW=80 um  Temp=25  NOISE=1  S_Deb=1
;
; -- GBIAS_Q1a  [PASSIVE_NETWORK]  Gate bias network Q1a (gate=ng_Q1a)
; -- GBIAS_Q1a skipped (add gate bias after FET verification)
;
; -- Q3a  [TRANSISTOR]  Stage 1 shunt pHEMT Q3a, OFF state (absorptive), 100um
"PP1029_CPW_PDK":Q3a  ng_Q3a n8 ns2_Q3a  NOF=2  UGW=50 um  Temp=25  NOISE=1  S_Deb=1
; kept passives for Q3a:
R:Rtrm1     ns2_Q3a ns3  R=47 Ohm
L:Lrt_Q3a   ns3     0    L=25 pH
;
; -- GBIAS_Q3a  [PASSIVE_NETWORK]  Gate bias network Q3a (gate=ng_Q3a)
; -- GBIAS_Q3a skipped (add gate bias after FET verification)
;
; -- Q1b  [TRANSISTOR]  Stage 2 series pHEMT Q1b, ON state, 160um
"PP1029_CPW_PDK":Q1b  ng_Q1b n8 n12  NOF=2  UGW=80 um  Temp=25  NOISE=1  S_Deb=1
;
; -- GBIAS_Q1b  [PASSIVE_NETWORK]  Gate bias network Q1b (gate=ng_Q1b)
; -- GBIAS_Q1b skipped (add gate bias after FET verification)
;
; -- Q3b  [TRANSISTOR]  Stage 2 shunt pHEMT Q3b, OFF state (absorptive), 100um
"PP1029_CPW_PDK":Q3b  ng_Q3b n12 ns2_Q3b  NOF=2  UGW=50 um  Temp=25  NOISE=1  S_Deb=1
; kept passives for Q3b:
R:Rtrm2     ns2_Q3b ns6  R=47 Ohm
L:Lrt_Q3b   ns6     0    L=25 pH
;
; -- GBIAS_Q3b  [PASSIVE_NETWORK]  Gate bias network Q3b (gate=ng_Q3b)
; -- GBIAS_Q3b skipped (add gate bias after FET verification)
;
; -- INT_out  [TLINE]  Output 0.3mm Au interconnect, pi-model
C:Co1a  n12  0    C=24 fF
R:Ro1   n12  n13  R=0.009 Ohm
L:Lo1   n13  n14  L=120 pH
C:Co1b  n14  0    C=24 fF
;
